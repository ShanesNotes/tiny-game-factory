{
  "name": "game-design",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "game-design — spec-only discipline repo in game-studio. Fertilizes a one-line game seed through a depth-gated thesis and decomposes it into an issue-sliced spec pack for co-development elsewhere. Formerly tiny-game-factory.",
  "scripts": {
    "verify:tools": "node scripts/verify-local-tools.mjs",
    "init:run": "node scripts/init-game-run.mjs",
    "portfolio:digest": "node scripts/build-portfolio-digest.mjs",
    "g1:brief": "node scripts/generate-g1-brief.mjs",
    "seed:auto": "node scripts/generate-seed-brief.mjs",
    "idea:walk": "node scripts/walk-game-idea.mjs",
    "emit:issues": "node scripts/emit-local-issues.mjs",
    "spec:probe": "node scripts/probe-spec-availability.mjs",
    "spec:package": "node scripts/package-spec.mjs",
    "spec:revise": "node scripts/package-spec.mjs",
    "gates": "node scripts/run-gates.mjs --dry-run",
    "validate": "node scripts/validate-artifacts.mjs --check all",
    "validate:reference-cards": "node scripts/validate-reference-cards.mjs",
    "test": "node --test \"tests/**/*.test.mjs\"",
    "lint": "node scripts/lint.mjs",
    "verify": "npm run lint && npm run validate && npm run validate:reference-cards && npm run gates && npm test"
  }
}
