{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tiny Game Factory Depth Vector",
  "type": "object",
  "additionalProperties": false,
  "required": ["scores", "total", "verdict"],
  "properties": {
    "schema_version": { "enum": ["2.0.0"] },
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "meaningful_choice",
        "tradeoff",
        "pressure",
        "uncertainty",
        "progression",
        "mastery",
        "combinatorial",
        "emergence",
        "replayable_variation",
        "failure_recovery",
        "expression",
        "expansion_headroom"
      ],
      "properties": {
        "meaningful_choice": { "type": "integer", "minimum": 0, "maximum": 2 },
        "tradeoff": { "type": "integer", "minimum": 0, "maximum": 2 },
        "pressure": { "type": "integer", "minimum": 0, "maximum": 2 },
        "uncertainty": { "type": "integer", "minimum": 0, "maximum": 2 },
        "progression": { "type": "integer", "minimum": 0, "maximum": 2 },
        "mastery": { "type": "integer", "minimum": 0, "maximum": 2 },
        "combinatorial": { "type": "integer", "minimum": 0, "maximum": 2 },
        "emergence": { "type": "integer", "minimum": 0, "maximum": 2 },
        "replayable_variation": { "type": "integer", "minimum": 0, "maximum": 2 },
        "failure_recovery": { "type": "integer", "minimum": 0, "maximum": 2 },
        "expression": { "type": "integer", "minimum": 0, "maximum": 2 },
        "expansion_headroom": { "type": "integer", "minimum": 0, "maximum": 2 }
      }
    },
    "total": { "type": "integer", "minimum": 0, "maximum": 24 },
    "register": { "enum": ["mechanics-first", "narrative-first", "hybrid", "world-first"] },
    "evidence": {
      "type": ["array", "object"],
      "items": { "type": "string" },
      "additionalProperties": false,
      "required": [
        "meaningful_choice",
        "tradeoff",
        "pressure",
        "uncertainty",
        "progression",
        "mastery",
        "combinatorial",
        "emergence",
        "replayable_variation",
        "failure_recovery",
        "expression",
        "expansion_headroom"
      ],
      "properties": {
        "meaningful_choice": { "type": "string" },
        "tradeoff": { "type": "string" },
        "pressure": { "type": "string" },
        "uncertainty": { "type": "string" },
        "progression": { "type": "string" },
        "mastery": { "type": "string" },
        "combinatorial": { "type": "string" },
        "emergence": { "type": "string" },
        "replayable_variation": { "type": "string" },
        "failure_recovery": { "type": "string" },
        "expression": { "type": "string" },
        "expansion_headroom": { "type": "string" }
      }
    },
    "review_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "reviewer_note"],
      "properties": {
        "mode": { "enum": ["independent", "same-context"] },
        "reviewer_note": { "type": "string" }
      }
    },
    "verdict": { "enum": ["ADVANCE", "DEEPEN", "KILL"] }
  },
  "if": {
    "required": ["schema_version"],
    "properties": { "schema_version": { "enum": ["2.0.0"] } }
  },
  "then": {
    "required": ["schema_version", "evidence", "review_provenance"],
    "properties": { "evidence": { "type": "object" } }
  }
}
