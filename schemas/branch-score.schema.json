{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tiny Game Factory Branch Score",
  "type": "object",
  "required": [
    "branch",
    "anti_boring_pass",
    "depth_total",
    "skill_spread",
    "replay_variation",
    "loop_completion_rate",
    "code_health",
    "verdict"
  ],
  "properties": {
    "branch": { "type": "string" },
    "anti_boring_pass": { "type": "boolean" },
    "depth_total": { "type": "integer", "minimum": 0, "maximum": 24 },
    "skill_spread": { "type": "number" },
    "replay_variation": { "type": "number" },
    "loop_completion_rate": { "type": "number" },
    "code_health": { "type": "number" },
    "verdict": { "enum": ["WINNER", "ADVANCE", "DEEPEN", "KILL", "DISCARD_ALL"] }
  }
}
