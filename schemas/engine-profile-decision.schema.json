{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tiny Game Factory Engine / Profile Decision",
  "type": "object",
  "additionalProperties": false,
  "required": ["seed_id", "status", "decision", "profile", "rationale", "rejected", "reversal_triggers"],
  "properties": {
    "seed_id": { "type": "string" },
    "status": { "enum": ["proposed", "accepted", "superseded", "rejected"] },
    "date": { "type": "string" },
    "decision": { "type": "string" },
    "profile": { "type": "string" },
    "godot_min": { "type": "string" },
    "godot_max": { "type": "string" },
    "renderer": { "type": "string" },
    "language": { "type": "string" },
    "rationale": { "type": "string" },
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "headless_testability": { "type": "integer", "minimum": 0, "maximum": 2 },
        "iteration_speed": { "type": "integer", "minimum": 0, "maximum": 2 },
        "fantasy_fit": { "type": "integer", "minimum": 0, "maximum": 2 },
        "core_loop_fit": { "type": "integer", "minimum": 0, "maximum": 2 },
        "deterministic_sim": { "type": "integer", "minimum": 0, "maximum": 2 },
        "migration_cost": { "type": "integer", "minimum": 0, "maximum": 2 },
        "visual_wow_no_game_risk": { "type": "integer", "minimum": 0, "maximum": 2 },
        "editor_opacity_risk": { "type": "integer", "minimum": 0, "maximum": 2 },
        "toolchain_verified": { "type": "integer", "minimum": 0, "maximum": 2 }
      }
    },
    "rejected": { "type": "array", "items": { "type": "object" } },
    "reversal_triggers": { "type": "array", "minItems": 1, "items": { "type": "string" } }
  }
}
