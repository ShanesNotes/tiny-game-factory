{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tiny Game Factory Seed Run Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "seed_id",
    "factory_version",
    "current_phase",
    "seed_path",
    "external_side_effects_allowed",
    "execution_ledger_path",
    "resume_point"
  ],
  "properties": {
    "seed_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$" },
    "factory_version": { "type": "string" },
    "current_phase": {
      "enum": [
        "intake", "toolchain", "thesis", "design-review", "deepen",
        "engine-profile", "decompose", "handoff",
        "blocked", "failed", "killed", "complete"
      ]
    },
    "design_lane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "stop_line", "origination"],
      "properties": {
        "mode": { "enum": ["grill", "yolo"] },
        "stop_line": { "enum": ["pack", "design-lock"] },
        "origination": { "enum": ["user", "auto"] }
      },
      "if": {
        "properties": { "mode": { "enum": ["grill"] } }
      },
      "then": {
        "properties": { "stop_line": { "enum": ["pack"] } }
      }
    },
    "seed_path": { "type": "string" },
    "game_thesis_path": { "type": ["string", "null"] },
    "engine_decision_path": { "type": ["string", "null"] },
    "spec_path": { "type": ["string", "null"] },
    "default_spec_pack_root": { "type": "string" },
    "spec_pack_path": { "type": ["string", "null"] },
    "external_side_effects_allowed": { "type": "boolean" },
    "execution_ledger_path": { "type": "string" },
    "review_report_paths": { "type": "array", "items": { "type": "string" } },
    "handoff_paths": { "type": "array", "items": { "type": "string" } },
    "resume_point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "artifact_path", "reason"],
      "properties": {
        "phase": { "type": "string" },
        "artifact_path": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "questions_asked": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question", "recommended_default", "phase_asked"],
        "properties": {
          "question": { "type": "string" },
          "recommended_default": { "type": "string" },
          "answer": { "type": "string" },
          "phase_asked": { "type": "string" },
          "actor": { "type": "string" }
        }
      }
    },
    "deepen_attempt_count": { "type": "integer", "minimum": 0 },
    "last_verified_at": { "type": ["string", "null"] }
  }
}
