{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Game Design Spec Decomposition",
  "type": "object",
  "additionalProperties": false,
  "required": ["seed_id", "chosen_loop_id", "summary", "slices"],
  "properties": {
    "seed_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$" },
    "chosen_loop_id": { "type": "string" },
    "summary": { "type": "string" },
    "out_of_scope": { "type": "array", "items": { "type": "string" } },
    "asset_source_policy": {
      "type": "string",
      "description": "Design taste gate for art sourcing. local = purchased library only; imagine = Grok Imagine for generatable 2D sprites (other kinds still library); combo = library first, then authorized Imagine on miss. Default when omitted: local.",
      "enum": ["local", "imagine", "combo"]
    },
    "asset_requests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["request_id", "role", "kind", "constraints", "substitution_policy"],
        "properties": {
          "request_id": { "type": "string" },
          "role": { "type": "string" },
          "kind": { "enum": ["sprite", "model", "animation", "audio"] },
          "query": { "type": "string" },
          "pack_id": { "type": "string" },
          "name": { "type": "string" },
          "derive": {
            "type": "object",
            "description": "Request-local authorization to derive a game-local model from a purchased-pack base through a reviewed recipe (forge-manifest 1.3.0). Presence = authorization (Shane 2026-07-19). Recipe ids from assets _tools/derive/ registry.",
            "additionalProperties": false,
            "required": ["base", "recipe"],
            "properties": {
              "base": {
                "type": "object",
                "additionalProperties": false,
                "required": ["pack_id", "name"],
                "properties": {
                  "pack_id": { "type": "string", "minLength": 1 },
                  "name": { "type": "string", "minLength": 1 }
                }
              },
              "recipe": { "type": "string", "minLength": 1 },
              "params": { "type": "object" }
            }
          },
          "constraints": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "rig": { "type": "string" },
              "clips": { "type": "array", "items": { "type": "string" } },
              "dimensions": { "type": "array", "items": { "type": "number" } },
              "perspective": { "type": "string" }
            }
          },
          "substitution_policy": { "enum": ["allow", "report", "block"] }
        }
      }
    },
    "lore_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["motif_id", "affordance_claim", "required"],
        "properties": {
          "motif_id": { "type": "string" },
          "affordance_claim": { "type": "string" },
          "required": { "type": "boolean", "enum": [false] }
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "persistence", "localization", "accessibility", "multiplayer",
        "world_gen", "modding", "telemetry"
      ],
      "properties": {
        "persistence": { "type": "boolean" },
        "localization": { "type": "boolean" },
        "accessibility": { "type": "boolean" },
        "multiplayer": { "type": "boolean" },
        "world_gen": { "type": "boolean" },
        "modding": { "type": "boolean" },
        "telemetry": { "type": "boolean" }
      }
    },
    "verify_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["golden_cameras", "frame_budget_ms", "load_budget_s"],
      "properties": {
        "golden_cameras": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "position", "target"],
            "properties": {
              "id": { "type": "string" },
              "position": { "type": "array", "items": { "type": "number" } },
              "target": { "type": "array", "items": { "type": "number" } }
            }
          }
        },
        "frame_budget_ms": { "type": "number" },
        "load_budget_s": { "type": "number" }
      }
    },
    "playable_baseline": {
      "type": "object",
      "description": "The studio's minimal every-game floor (ADR 0013): boot, controls, ui, outcome — each mapped to a planned slice. Optional here so recorded legacy runs keep validating; required at package/export time by the forge-manifest mapper (gate policy in checkers, ADR 0005), which also enforces slice resolution and the pause-surface rule.",
      "additionalProperties": false,
      "required": ["boot", "controls", "ui", "outcome"],
      "properties": {
        "boot": {
          "type": "object",
          "additionalProperties": false,
          "required": ["entry_scene", "slice"],
          "properties": {
            "entry_scene": { "type": "string" },
            "slice": { "type": "string" }
          }
        },
        "controls": {
          "type": "object",
          "additionalProperties": false,
          "required": ["actions", "consumer_paths", "slice"],
          "properties": {
            "actions": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["action", "verb"],
                "properties": {
                  "action": { "type": "string" },
                  "verb": { "type": "string" }
                }
              }
            },
            "consumer_paths": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "slice": { "type": "string" }
          }
        },
        "ui": {
          "type": "object",
          "additionalProperties": false,
          "required": ["surfaces", "slice"],
          "properties": {
            "surfaces": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "provides", "path"],
                "properties": {
                  "id": { "type": "string" },
                  "provides": { "type": "string" },
                  "path": { "type": "string" }
                }
              }
            },
            "slice": { "type": "string" }
          }
        },
        "outcome": {
          "type": "object",
          "additionalProperties": false,
          "required": ["states", "communicated_by", "path", "slice"],
          "properties": {
            "states": { "type": "array", "minItems": 2, "items": { "type": "string" } },
            "communicated_by": { "type": "string" },
            "path": { "type": "string" },
            "slice": { "type": "string" }
          }
        }
      }
    },
    "slices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "type", "order", "goal", "acceptance"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$" },
          "title": { "type": "string" },
          "type": { "enum": ["slice", "feature", "chore", "seam"] },
          "order": { "type": "integer", "minimum": 1 },
          "goal": { "type": "string" },
          "acceptance": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "statement", "check"],
              "properties": {
                "kind": {
                  "enum": ["mechanical", "visual", "feel_budget", "animation_cycle", "performance"]
                },
                "statement": { "type": "string" },
                "check": { "type": "string" }
              }
            }
          },
          "evidence_requirements": { "type": "array", "items": { "type": "string" } },
          "depends_on": { "type": "array", "items": { "type": "string" } },
          "loop_verbs_covered": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "ext": {
      "type": "object",
      "description": "Optional export-time extensions. Discipline tags under ext.disciplines are validated by the forge-manifest mapper (ADR-0005), not this schema.",
      "properties": {
        "disciplines": {
          "type": "object",
          "description": "Acceptance-level discipline tags: { slice_id: { acceptance_key_or_check_id | _default: discipline } }. Enum enforced at map time."
        }
      }
    }
  }
}
